# The m-p-proxmox-06 bug: crypt-nvme6n1 and crypt-nvme7n1 share one UUID
# (duplicate), and crypt-nvme5n1 carries nvme7's real UUID. -> exit 2 (HARD).
crypt-nvme6n1 UUID=7413df54-dd88-4b52-8bf8-c3ca15638dbc none luks,discard,noauto,nofail,_netdev,x-systemd.after=network-online.target
crypt-nvme7n1 UUID=7413df54-dd88-4b52-8bf8-c3ca15638dbc none luks,discard,noauto,nofail,_netdev,x-systemd.after=network-online.target
crypt-nvme5n1 UUID=50ca1601-5785-4ac0-b262-8cae7b29e011 none luks,discard,noauto,nofail,_netdev,x-systemd.after=network-online.target
